# Base de datos (PostgreSQL)
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
# Ejemplo local: postgresql://postgres:postgres@localhost:5432/mi_rotaract
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mi_rotaract"

# API
PORT=3001
JWT_SECRET="cambiar-en-produccion"
CORS_ORIGIN="http://localhost:3000"

# Web (frontend)
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Opcional: si la URL del WebSocket es distinta a la API
# NEXT_PUBLIC_WS_URL="http://localhost:3001"

# Storage (adjuntos/evidencias)
# r2 = Cloudflare R2 | fs = filesystem local
# Para desarrollo local sin R2: STORAGE_ADAPTER=fs
STORAGE_ADAPTER="r2"

# Cloudflare R2 (requerido si STORAGE_ADAPTER=r2)
# https://developers.cloudflare.com/r2/api/s3/tokens/
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="mi-rotaract-attachments"
# Opcional: URL base pública si el bucket tiene dominio custom
# R2_PUBLIC_BASE_URL="https://..."

# Fallback filesystem (si STORAGE_ADAPTER=fs)
# UPLOAD_DIR="uploads"
