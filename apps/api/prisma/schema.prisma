generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PARTICIPANT
  SECRETARY
  PRESIDENT
  COMPANY
}

enum ClubStatus {
  ACTIVE
  INACTIVE
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  LICENCIA
  EGRESADO
  PENDIENTE
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  OBSERVED
  APPROVED
  REJECTED
}

enum ReportType {
  MENSUAL
  TRIMESTRAL
  ANUAL
}

enum CommitteeStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum MeetingStatus {
  DRAFT
  SCHEDULED
  LIVE
  PAUSED
  FINISHED
  ARCHIVED
}

enum AttendanceStatus {
  INVITED
  JOINED
  LEFT
}

enum TopicType {
  DISCUSSION
  VOTING
  INFORMATIVE
}

enum TopicStatus {
  PENDING
  ACTIVE
  DONE
}

model User {
  id                    String              @id @default(cuid())
  fullName              String
  email                 String              @unique
  passwordHash          String
  role                  Role
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  memberships           Membership[]
  createdMeetings       Meeting[]           @relation("MeetingCreator")
  meetingParticipants   MeetingParticipant[]
  speakingRequests      SpeakingRequest[]
  reportsReviewed       Report[]
  committeesCoordinated Committee[]         @relation("CommitteeCoordinator")
  committeeMemberships  CommitteeMember[]
  organizedEvents       Event[]             @relation("EventOrganizer")
  attachments           Attachment[]
  assignedProjects      Project[]           @relation("ProjectAssignee")
  profile               UserProfile?
  createdOpportunities  Opportunity[]
  memberProfiles        Member[]
  passwordResetTokens   PasswordResetToken[]
  company               Company?
  talentContactRequests TalentContactRequest[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([expiresAt])
}

enum OpportunityType {
  EMPLEO
  PASANTIA
  BECA
  VOLUNTARIADO
  CAPACITACION
  LIDERAZGO
  CONVOCATORIA
}

enum OpportunityModality {
  PRESENCIAL
  VIRTUAL
  HIBRIDA
}

enum OpportunityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Opportunity {
  id           String              @id @default(cuid())
  title        String
  description  String?             @db.Text
  requirements String?             @db.Text
  type         OpportunityType
  modality     OpportunityModality
  area         String?
  organization String?
  externalUrl  String?
  deadlineAt   DateTime?
  status       OpportunityStatus   @default(DRAFT)
  featured     Boolean             @default(false)
  createdById  String
  publishedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  creator      User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  @@index([status, deadlineAt])
  @@index([type])
  @@index([organization])
}

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  photoUrl           String?
  profession         String?
  bio                String?  @db.Text
  city               String?
  linkedInUrl        String?
  skills             String[] @default([])
  interests          String[] @default([])
  experienceJson     String?
  educationJson      String?
  languagesJson      String?
  availability       String?
  contactEmailPublic Boolean  @default(false)
  talentVisible      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([talentVisible])
}

model Club {
  id                       String     @id @default(cuid())
  name                     String
  code                     String     @unique
  status                   ClubStatus @default(ACTIVE)
  presidentEmail           String?
  enabledForDistrictMeetings Boolean  @default(true)
  cuotaAldia               Boolean    @default(false)
  informeAlDia             Boolean    @default(false)
  logoUrl                  String?
  city                     String?
  zone                     String?
  foundedAt                DateTime?
  description              String?
  contactEmail             String?
  contactPhone             String?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  memberships              Membership[]
  members                  Member[]
  meetings                 Meeting[]
  reports                  Report[]
  events                   Event[]
  projects                 Project[]
  auditLogs                AuditLog[]
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  clubId     String
  title      String?
  isPresident Boolean @default(false)
  activeFrom DateTime @default(now())
  activeUntil DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
}

model Member {
  id            String       @id @default(cuid())
  clubId        String
  userId        String?
  firstName     String
  lastName      String
  email         String
  phone         String?
  birthDate     DateTime?
  joinedAt      DateTime?
  status        MemberStatus @default(PENDIENTE)
  title         String?
  isPresident   Boolean      @default(false)
  internalNotes String?      @db.Text
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  club          Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([clubId, email])
  @@unique([clubId, userId])
  @@index([clubId, status])
  @@index([clubId, deletedAt])
  @@index([clubId, title])
}

model Meeting {
  id             String        @id @default(cuid())
  title          String
  description    String?
  scheduledAt    DateTime?
  startedAt      DateTime?
  endedAt       DateTime?
  status         MeetingStatus @default(DRAFT)
  currentTopicId String?
  createdById    String
  clubId         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  creator        User          @relation("MeetingCreator", fields: [createdById], references: [id])
  club           Club          @relation(fields: [clubId], references: [id])
  participants   MeetingParticipant[]
  topics         AgendaTopic[]
  voteSessions   VoteSession[]
  speakingRequests SpeakingRequest[]
  currentSpeakerId String?
  nextSpeakerId   String?
  timerSessions  TimerSession[]
  auditLogs      AuditLog[]
  @@index([clubId])
  @@index([status, scheduledAt])
}

model AgendaTopic {
  id                  String      @id @default(cuid())
  meetingId           String
  title               String
  description         String?
  order               Int         @default(0)
  type                TopicType   @default(DISCUSSION)
  estimatedDurationSec Int?
  status              TopicStatus @default(PENDING)
  meeting             Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  voteSessions        VoteSession[]
  @@index([meetingId, order])
}

enum VoteSessionStatus {
  OPEN
  CLOSED
}

enum VoteChoice {
  YES
  NO
  ABSTAIN
}

model VoteSession {
  id        String            @id @default(cuid())
  meetingId String
  topicId   String
  status    VoteSessionStatus @default(OPEN)
  openedAt  DateTime          @default(now())
  closedAt  DateTime?
  openedById String?
  closedById String?
  votes     Vote[]
  topic     AgendaTopic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  meeting   Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  @@index([meetingId, status])
}

model Vote {
  id           String    @id @default(cuid())
  voteSessionId String
  userId      String
  choice      VoteChoice
  createdAt   DateTime  @default(now())
  session     VoteSession @relation(fields: [voteSessionId], references: [id], onDelete: Cascade)
  @@unique([voteSessionId, userId])
  @@index([voteSessionId])
}

model MeetingParticipant {
  id              String           @id @default(cuid())
  meetingId       String
  userId          String
  canVote         Boolean          @default(true)
  attendanceStatus AttendanceStatus @default(INVITED)
  joinedAt        DateTime?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting         Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  FINISHED
}

enum EventType {
  DISTRITAL
  CLUB
  CAPACITACION
  REUNION
  ASAMBLEA
  PROYECTO_SERVICIO
  NETWORKING
  PROFESIONAL
}

enum EventModality {
  PRESENCIAL
  VIRTUAL
  HIBRIDA
}

enum SpeakingRequestStatus {
  PENDING
  ACCEPTED
  CANCELLED
  DONE
}

model SpeakingRequest {
  id          String                @id @default(cuid())
  meetingId   String
  userId      String
  status      SpeakingRequestStatus @default(PENDING)
  position    Int                   @default(0)
  requestedAt DateTime             @default(now())
  acceptedAt  DateTime?
  meeting     Meeting               @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([meetingId, status])
}

model TimerSession {
  id                String    @id @default(cuid())
  meetingId         String
  topicId           String?
  speakingRequestId String?
  type              String    // TOPIC | SPEAKER
  plannedDurationSec Int
  startedAt         DateTime  @default(now())
  pausedAt          DateTime?
  endedAt           DateTime?
  overtimeSec       Int       @default(0)
  meeting           Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  @@index([meetingId])
}

model AuditLog {
  id           String   @id @default(cuid())
  meetingId    String?
  clubId       String?
  actorUserId  String?
  action       String
  entityType   String?
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())
  meeting      Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  club         Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  @@index([meetingId, createdAt])
  @@index([clubId, createdAt])
}

model HealthCheck {
  id        String   @id @default(cuid())
  checkedAt DateTime @default(now())
}

model DistrictPeriod {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reports   Report[]
  committees Committee[]
  @@index([startDate, endDate])
}

model Report {
  id                     String       @id @default(cuid())
  clubId                 String
  districtPeriodId       String
  type                   ReportType
  status                 ReportStatus  @default(DRAFT)
  contentJson            String?      // contenido libre o estructurado
  observations           String?      // observaciones del distrito
  responseToObservations String?      // respuesta del club cuando OBSERVED/REJECTED
  submittedAt            DateTime?
  resubmittedAt          DateTime?    // cuándo se reenvió tras corrección
  reviewedAt             DateTime?
  reviewedById           String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  club                   Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  districtPeriod         DistrictPeriod @relation(fields: [districtPeriodId], references: [id], onDelete: Cascade)
  reviewer               User?        @relation(fields: [reviewedById], references: [id], onDelete: SetNull)
  @@unique([clubId, districtPeriodId, type])
  @@index([clubId])
  @@index([districtPeriodId])
  @@index([status])
}

model Committee {
  id                String          @id @default(cuid())
  name              String
  description       String?
  coordinatorId     String
  status            CommitteeStatus @default(ACTIVE)
  districtPeriodId  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  coordinator       User            @relation("CommitteeCoordinator", fields: [coordinatorId], references: [id], onDelete: Cascade)
  districtPeriod    DistrictPeriod? @relation(fields: [districtPeriodId], references: [id], onDelete: SetNull)
  members           CommitteeMember[]
  objectives        CommitteeObjective[]
  activities        CommitteeActivity[]
  @@index([status])
  @@index([coordinatorId])
}

model CommitteeMember {
  id          String   @id @default(cuid())
  committeeId String
  userId      String
  role        String?  // opcional: ej. "integrante", "secretario"
  joinedAt    DateTime @default(now())
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([committeeId, userId])
  @@index([committeeId])
  @@index([userId])
}

model CommitteeObjective {
  id          String   @id @default(cuid())
  committeeId String
  title       String
  description String?
  order       Int      @default(0)
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  @@index([committeeId, order])
}

model CommitteeActivity {
  id          String   @id @default(cuid())
  committeeId String
  title       String
  date       DateTime
  notes       String?
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  @@index([committeeId])
}

model Event {
  id          String         @id @default(cuid())
  title       String
  description String?
  type        EventType
  modality    EventModality
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  meetingUrl  String?
  maxCapacity Int?
  status      EventStatus    @default(DRAFT)
  featured    Boolean        @default(false)
  imageUrl    String?
  clubId      String?
  organizerId String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  club        Club?          @relation(fields: [clubId], references: [id], onDelete: SetNull)
  organizer   User           @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([status, startsAt])
  @@index([clubId])
  @@index([organizerId])
  @@index([featured, status, startsAt])
}

enum ProjectStatus {
  IDEA
  PLANIFICACION
  EN_EJECUCION
  FINALIZADO
  CANCELADO
}

enum ProjectCategory {
  SOCIAL
  PROFESIONAL
  AMBIENTAL
  OTRO
}

model Project {
  id           String          @id @default(cuid())
  clubId       String
  title        String
  description  String?
  status       ProjectStatus   @default(IDEA)
  category     ProjectCategory?
  startDate    DateTime?
  endDate      DateTime?
  assignedToId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  club         Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  assignedTo   User?           @relation("ProjectAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  progress     ProjectProgress[]
  @@index([clubId])
  @@index([clubId, status])
}

model ProjectProgress {
  id           String   @id @default(cuid())
  projectId    String
  description  String
  progressDate DateTime
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
}

model Attachment {
  id             String   @id @default(cuid())
  entityType     String   // "report" | "project" | "event" | "committee_activity" | "meeting"
  entityId       String
  fileName       String
  mimeType       String?
  sizeBytes      Int?
  storageKey     String
  storageBackend String   @default("r2") // "r2" | "fs" (para migración)
  uploadedById   String
  uploadedAt     DateTime @default(now())
  user           User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  @@index([entityType, entityId])
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model Company {
  id           String        @id @default(cuid())
  name         String
  country      String?
  city         String?
  industry     String?
  size         String?
  website      String?
  contactName  String
  contactEmail String
  phone        String?
  status       CompanyStatus @default(PENDING)
  ownerUserId  String       @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  owner        User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  contactRequests TalentContactRequest[]

  @@index([status])
}

enum TalentContactRequestStatus {
  NEW
  SHARED_WITH_MEMBER
  CLOSED
}

model TalentContactRequest {
  id              String                     @id @default(cuid())
  companyId       String
  talentUserId    String
  message         String?
  status          TalentContactRequestStatus @default(NEW)
  createdAt       DateTime                   @default(now())
  handledAt       DateTime?
  handledByUserId String?

  company         Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  talentUser      User                       @relation(fields: [talentUserId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([talentUserId])
  @@index([status, createdAt])
}
