generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PARTICIPANT
  SECRETARY
  PRESIDENT
}

enum ClubStatus {
  ACTIVE
  INACTIVE
}

enum MeetingStatus {
  DRAFT
  SCHEDULED
  LIVE
  PAUSED
  FINISHED
  ARCHIVED
}

enum AttendanceStatus {
  INVITED
  JOINED
  LEFT
}

enum TopicType {
  DISCUSSION
  VOTING
  INFORMATIVE
}

enum TopicStatus {
  PENDING
  ACTIVE
  DONE
}

model User {
  id               String              @id @default(cuid())
  fullName         String
  email            String              @unique
  passwordHash     String
  role             Role
  isActive         Boolean             @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  memberships      Membership[]
  createdMeetings  Meeting[]          @relation("MeetingCreator")
  meetingParticipants MeetingParticipant[]
  speakingRequests SpeakingRequest[]
}

model Club {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  status    ClubStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  memberships Membership[]
  meetings  Meeting[]
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  clubId     String
  title      String?
  isPresident Boolean @default(false)
  activeFrom DateTime @default(now())
  activeUntil DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
}

model Meeting {
  id             String        @id @default(cuid())
  title          String
  description    String?
  scheduledAt    DateTime?
  startedAt      DateTime?
  endedAt       DateTime?
  status         MeetingStatus @default(DRAFT)
  currentTopicId String?
  createdById    String
  clubId         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  creator        User          @relation("MeetingCreator", fields: [createdById], references: [id])
  club           Club          @relation(fields: [clubId], references: [id])
  participants   MeetingParticipant[]
  topics         AgendaTopic[]
  voteSessions   VoteSession[]
  speakingRequests SpeakingRequest[]
  currentSpeakerId String?
  nextSpeakerId   String?
  timerSessions  TimerSession[]
  auditLogs      AuditLog[]
  @@index([clubId])
  @@index([status, scheduledAt])
}

model AgendaTopic {
  id                  String      @id @default(cuid())
  meetingId           String
  title               String
  description         String?
  order               Int         @default(0)
  type                TopicType   @default(DISCUSSION)
  estimatedDurationSec Int?
  status              TopicStatus @default(PENDING)
  meeting             Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  voteSessions        VoteSession[]
  @@index([meetingId, order])
}

enum VoteSessionStatus {
  OPEN
  CLOSED
}

enum VoteChoice {
  YES
  NO
  ABSTAIN
}

model VoteSession {
  id        String            @id @default(cuid())
  meetingId String
  topicId   String
  status    VoteSessionStatus @default(OPEN)
  openedAt  DateTime          @default(now())
  closedAt  DateTime?
  openedById String?
  closedById String?
  votes     Vote[]
  topic     AgendaTopic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  meeting   Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  @@index([meetingId, status])
}

model Vote {
  id           String    @id @default(cuid())
  voteSessionId String
  userId      String
  choice      VoteChoice
  createdAt   DateTime  @default(now())
  session     VoteSession @relation(fields: [voteSessionId], references: [id], onDelete: Cascade)
  @@unique([voteSessionId, userId])
  @@index([voteSessionId])
}

model MeetingParticipant {
  id              String           @id @default(cuid())
  meetingId       String
  userId          String
  canVote         Boolean          @default(true)
  attendanceStatus AttendanceStatus @default(INVITED)
  joinedAt        DateTime?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting         Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

enum SpeakingRequestStatus {
  PENDING
  ACCEPTED
  CANCELLED
  DONE
}

model SpeakingRequest {
  id          String                @id @default(cuid())
  meetingId   String
  userId      String
  status      SpeakingRequestStatus @default(PENDING)
  position    Int                   @default(0)
  requestedAt DateTime             @default(now())
  acceptedAt  DateTime?
  meeting     Meeting               @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([meetingId, status])
}

model TimerSession {
  id                String    @id @default(cuid())
  meetingId         String
  topicId           String?
  speakingRequestId String?
  type              String    // TOPIC | SPEAKER
  plannedDurationSec Int
  startedAt         DateTime  @default(now())
  pausedAt          DateTime?
  endedAt           DateTime?
  overtimeSec       Int       @default(0)
  meeting           Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  @@index([meetingId])
}

model AuditLog {
  id           String   @id @default(cuid())
  meetingId    String?
  actorUserId  String?
  action       String
  entityType   String?
  entityId     String?
  metadataJson String?
  createdAt    DateTime @default(now())
  meeting      Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  @@index([meetingId, createdAt])
}

model HealthCheck {
  id        String   @id @default(cuid())
  checkedAt DateTime @default(now())
}
