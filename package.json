{
  "name": "mi-rotaract",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mi-rotaract/shared-types run build && pnpm --filter web --filter api --parallel run dev",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:migrate": "pnpm --filter api run prisma:migrate",
    "db:push": "pnpm --filter api run prisma:push",
    "db:seed": "pnpm --filter api run prisma:seed"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "@nestjs/core"
    ]
  }
}
