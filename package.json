{
  "name": "mi-rotaract",
  "private": true,
  "scripts": {
    "dev": "pnpm run build --filter @mi-rotaract/shared-types && pnpm --filter web --filter api --parallel run dev",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:migrate": "pnpm --filter api run prisma:migrate",
    "db:push": "pnpm --filter api run prisma:push"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20"
  }
}
