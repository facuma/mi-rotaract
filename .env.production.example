# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# API
PORT=8091
NODE_ENV=production
JWT_SECRET="<generar-secreto-fuerte>"

# CORS — URL(s) del frontend, separadas por coma
CORS_ORIGIN="https://tu-frontend.vercel.app"

# Storage: "r2" o "fs"
STORAGE_ADAPTER="r2"

# Cloudflare R2 (requerido si STORAGE_ADAPTER=r2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="mi-rotaract-attachments"
# R2_PUBLIC_BASE_URL="https://..."

# URL del frontend (para links en emails de reset password)
FRONTEND_URL="https://tu-frontend.vercel.app"
